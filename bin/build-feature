#! /bin/bash

# This script will create a new document for the feature and then use the prompt to create a plan for the feature.


# General flow is
# - Source feature name from user + idea for feature
# - DESIGN.md (product discovery, requirements, etc)
# - RESEARCH.md
# - PLAN.md
# - Append checklist to PLAN.md
# - If plan is too complex, break down into smaller plans. 



#
# Validate input
#
if [[ -z "$1" || -z "$2" || -z "$3" ]]; then
  echo "Usage: build-feature <feature-name> <doc-directory> <prompt>"
  exit 1
fi

#
# Build out global variables
#
FEATURE_NAME="$1"
TIME_STAMP=$(date +%y%m%d%H%M)
DOC_DIRECTORY="$2/$TIME_STAMP-$FEATURE_NAME"

# Remove trailing slash from DOC_DIRECTORY if it exists
DOC_DIRECTORY="${DOC_DIRECTORY%/}"



PROMPT="${@:3}"
TERSENESS="Be concise and to the point. Stick to facts. Be succinct and terse. Don't be verbose."
CURSOR_MODEL=opus-4.5-thinking
CURSOR_MODEL=kimi-k2.5
IDE="cursor"
AGENT_TYPE="cursor"


mkdir -p $DOC_DIRECTORY

echo "==> Creating feature: $FEATURE_NAME in $DOC_DIRECTORY"

# Run an agent using Cursor
# Uses stdin to pass the prompt to the agent.
run_cursor_agent() {
  echo "==> Running cursor-agent for stage: $STAGE"
  echo "==> MODEL: $CURSOR_MODEL"

  local STDIN_PROMPT=$(cat) 
  echo "$STDIN_PROMPT"  

  if ! cursor-agent --model $CURSOR_MODEL "$STDIN_PROMPT"; then
    echo "ERROR: cursor-agent failed at stage: $STAGE" >&2
    exit 1
  fi
  echo "==> Stage: $STAGE completed"
}

run_claude_agent() {
  echo "==> Running claude for stage: $STAGE"

  local STDIN_PROMPT=$(cat) 
  echo "$STDIN_PROMPT"  

  if [[ "$AGENT_TYPE" == "claude" ]]; then
    if ! claude --dangerously-skip-permissions "$STDIN_PROMPT"; then
      echo "ERROR: claude failed at stage: $STAGE" >&2
      exit 1
    fi
  else
    if ! cursor-agent --model $CURSOR_MODEL "$STDIN_PROMPT"; then
      echo "ERROR: cursor-agent failed at stage: $STAGE" >&2
      exit 1
    fi
  fi
  echo "==> Stage: $STAGE completed"
}




# Creates a new document.
# $1: file name
# Returns the file path.
new_doc() {
    local FILE_NAME="$1"
    local FILE_PATH="$DOC_DIRECTORY/$FILE_NAME"
    echo $FILE_PATH
}

# Wait until the user has finished editing the document.
# If anything other than 'y|Y|yes|Yes|YES' is entered, keep looping.
wait_for_user() {
    # Claude doesn't need to wait for the user as we leave the agent running.
    if [[ "$AGENT_TYPE" == "claude" ]]; then
        return
    fi

    local FILE_PATH="$1"
    prompt="Have you finished editing the document $FILE_PATH? (y|n)
> "
    read -p "$prompt" response
    while [[ "$response" != "y" && "$response" != "Y" && "$response" != "yes" && "$response" != "Yes" && "$response" != "YES" ]]; do
        echo "==> Please enter 'y' or 'n'"
        read -p "$prompt" response
    done
    echo "==> User finished editing the document $FILE_PATH"
}

build_prompt() {
    local FILE_PATH="$1"
    local PROMPT_INPUT="${@:2}"
    local PROMPT="$PROMPT_INPUT

If anything is unknown or unclear, write it out.
$TERSENESS

Output everything to the file '$FILE_PATH'.

Open the file '$FILE_PATH' in the IDE '$IDE' so I can review it.

If possible, play an audio notification to alert me that the file is ready to review.

"

    echo "$PROMPT"
}


#
# Stage 1: Design
#
STAGE="DESIGN"
DESIGN_FILE="$(new_doc "01-design.md")"
DESIGN_PROMPT="You are an expert product manager and designer.
You are to help me design a new feature which should do the following:
$PROMPT

Explicitly outline any unknowns, questions, and any other details that are not clear.
The most important thing is to cover the entire user flow if relevant. Otherwise ask for high level features.
It is critical to include both the "happy" and "unhappy" flows in the design document.
Write out a testing plan and test cases for the feature.
However, do not go too deep at this stage. Stick to high level details.
"

build_prompt "$DESIGN_FILE" "$DESIGN_PROMPT" | run_claude_agent 
wait_for_user "$DESIGN_FILE"



#
# Stage 2:Research
#
STAGE="RESEARCH"
RESEARCH_FILE="$(new_doc "02-research.md")"
RESEARCH_PROMPT="You are helpful assistant that is an expert in software development, project planning, product discovery, and architecture.

You are tasked to work on $FEATURE_NAME.

You are given the following design document to reference:
$DESIGN_FILE

You need to research each element in depth, listing out the inticacies, challenges, and other details. 
List out any prior art and existing solutions found in the repo.
Analyze everything in great detail, providing deep research. Go through everything.
List out any relevant files and their file paths with a brief summary of how it is useful.
"

build_prompt "$RESEARCH_FILE" "$RESEARCH_PROMPT" | run_claude_agent 
wait_for_user "$RESEARCH_FILE"

#
# Stage 3: Plan
#
STAGE="PLAN"
PLAN_FILE="$(new_doc "03-plan.md")"
PLAN_PROMPT="
You are an expert at project management, development, architecture and design.
You prefer simple, robust solutions that are easy to maintain and extend.

You are tasked to work on $FEATURE_NAME.

You are given the following design document to reference:
$DESIGN_FILE

You are given the following research document to reference:
$RESEARCH_FILE

Write a detailed document outlining how to implement this. include code snippets.
Ensure that both '$DESIGN_FILE' and '$RESEARCH_FILE' are linked in the plan.
"

build_prompt "$PLAN_FILE" "$PLAN_PROMPT" | run_claude_agent 
wait_for_user "$PLAN_FILE"


#
# Stage 4: Checklist
# 
STAGE="CHECKLIST"
CHECKLIST_FILE="$(new_doc "04-checklist.md")"
CHECKLIST_PROMPT="Given the following plan file in '$PLAN_FILE', generate a checklist of tasks that need to be completed to implement the feature.
Be clear, concise, and explicit.
Split each task into smaller tasks if necessary.
Append the generated checklist to the end of the content in '$PLAN_FILE'.
"

build_prompt "$CHECKLIST_FILE" "$CHECKLIST_PROMPT" | run_claude_agent 
wait_for_user "$CHECKLIST_FILE"


#
# Stage 5: Implementation
#
STAGE="IMPLEMENTATION"
IMPLEMENTATION_PROMPT="You are an expert at software development, project management, architecture and design.
You prefer simple, robust solutions that are easy to maintain and extend.
Make code modular wherever possible.
You are tasked to work on $FEATURE_NAME.
Implement the following plan document in '$CHECKLIST_FILE'.
"

# Use a cheaper model for implementation. Experiment with Kimi-k2
CURSOR_MODEL=kimi-k2.5

echo "$IMPLEMENTATION_PROMPT" | run_claude_agent 


echo "==> Implementation completed"