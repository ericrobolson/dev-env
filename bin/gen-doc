#!/bin/bash

# This script will create a new document for a project.

# General flow is
# - Get doc name + document directory from user
# - Create a markdown file with the name and directory path
# - Work through the prompt and store everything in a markdown file.

# Source shared helpers
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$SCRIPT_DIR/helpers.sh" ]]; then
    source "$SCRIPT_DIR/helpers.sh"
else
    echo "Error: helpers.sh not found at $SCRIPT_DIR/helpers.sh" >&2
    exit 1
fi

# Input validation
validate_args_min 3 "gen-doc <doc-name> <doc-directory> <prompt>" "$@" || exit 1

# Arguments
DOC_NAME="$1"
DOC_DIRECTORY="${2%/}"
shift 2
PROMPT="$@"

# Initialize globals
init_globals || exit 1

# Build full directory path with timestamp
DOC_DIRECTORY="$DOC_DIRECTORY/$TIME_STAMP-$DOC_NAME"

# Create directory
mkdir -p "$DOC_DIRECTORY"

PROMPTS_FILE="$DOC_DIRECTORY/00-prompts.md"

# Build output path
FILE_PATH="$DOC_DIRECTORY/DOCUMENT.md"

echo "==> File path: $FILE_PATH"

# Build and execute prompt
PLAY_SOUND=$(play_sound)
FULL_PROMPT="You prefer simple, robust solutions that are easy to maintain and extend.
You are tasked to work on $DOC_NAME.

$PROMPT

When finished, run '$PLAY_SOUND' to play an audio notification."


FINAL_PROMPT=$(build_prompt "$FILE_PATH" "$FULL_PROMPT")
append_prompt "$PROMPTS_FILE" "Generate" "$FINAL_PROMPT"
echo "$FINAL_PROMPT" | run_agent "generate" || exit 1
append_resume "$PROMPTS_FILE"
